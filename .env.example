# ── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enneagram
POSTGRES_USER=enneagram_user
POSTGRES_PASSWORD=troque_esta_senha

# RDS/AWS: TLS é aplicado automaticamente se POSTGRES_HOST contiver .rds.amazonaws.com
# Forçar: POSTGRES_SSL=true | desligar: POSTGRES_SSL=false
# Verificação estrita do certificado (requer CA confiável): POSTGRES_SSL_REJECT_UNAUTHORIZED=true
# POSTGRES_SSL=true

# Máximo de conexões por instância (node-postgres Pool). Orçamento:
# max_connections no Postgres ≥ réplicas_app × PG_POOL_MAX × (1 se só primário, 2 se POSTGRES_READ_HOST definido).
# Ex.: 5 réplicas × 20 × 2 = 200 → reserve margem para admin/migrate.
PG_POOL_MAX=10

# Réplica só-leitura (opcional). Leituras pesadas (dashboard, export, links públicos GET) usam este host.
# POSTGRES_READ_PORT=5432
# POSTGRES_READ_SSL=true
# POSTGRES_READ_HOST=

# Métricas: GET /api/health (ping DB). Detalhes (filas do pool, latência): envie o mesmo valor em
# Authorization: Bearer … ou ?token=…
# HEALTH_METRICS_SECRET=

# ── Autenticação do gestor ───────────────────────────────────────────────────
# Conta admin inicial (bootstrap) — será criada automaticamente na primeira subida
BOOTSTRAP_ADMIN_EMAIL=admin@3035tech.com
BOOTSTRAP_ADMIN_PASSWORD=troque_esta_senha

# ── JWT ─────────────────────────────────────────────────────────────────────
# Desenvolvimento: pode omitir (usa fallback local) ou definir qualquer string.
# Produção (next start): obrigatório, ≥32 caracteres, não pode ser placeholder abaixo.
# Gere: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── E-mail (convites por vaga no painel) ─────────────────────────────────────
# SMTP de saída — necessário para «Enviar convite» na aba Vagas.
# 3035Tech: mail.3035tech.com — SSL na 465 (SMTP_SECURE=true) ou STARTTLS na 587 (SMTP_SECURE=false).
# Outros: Amazon SES, Gmail (app password), Mailgun, etc.
SMTP_HOST=mail.3035tech.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=team@3035tech.com
SMTP_PASS=
MAIL_FROM="30Team <team@3035tech.com>"

# ── Cron (lembretes de convite) ─────────────────────────────────────────────
# POST /api/cron/invite-reminders com header: Authorization: Bearer <CRON_SECRET>
# ou X-Cron-Secret: <CRON_SECRET>. NEXT_PUBLIC_APP_URL deve estar definido.
# CRON_SECRET=

# ── Retenção (LGPD) ──────────────────────────────────────────────────────────
# Ex.: 180 = apaga assessments e candidatos órfãos após 180 dias
RETENTION_DAYS=180
# Notas internas: docs/privacidade-lgpd-interno.md

# ── Legado: tabela results (global por nome) ─────────────────────────────────
# false (padrão se omitido): POST /api/results não grava em `results`; use só assessments.
# true: mantém INSERT … ON CONFLICT (LOWER(name)) para scripts/dashboards antigos.
# LEGACY_RESULTS_WRITE=false

# ── HTTPS / cabeçalhos extras (produção, domínio estável) ─────────────────────
# HSTS — só com HTTPS de ponta a ponta e sem necessidade de HTTP claro no mesmo host.
# ENABLE_HSTS=true
# HSTS_MAX_AGE=31536000
# HSTS_PRELOAD=false

# CSP só em modo relatório — ajuste ao stack (Next, inline styles, etc.) antes de bloquear.
# Exemplo minimalista (uma linha): restrige embed e base; permite inline como no app atual.
# CSP_REPORT_ONLY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
